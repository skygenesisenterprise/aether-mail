generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String?
  avatarUrl         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions         Session[]
  emails           Email[]
  contacts         Contact[]
  calendarEvents   CalendarEvent[]
  todos            Todo[]
  feeds            Feed[]
  feedArticles    FeedArticle[]
  bookmarks       Bookmark[]
  settings         UserSettings?
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt        Int?
  tokenType        String?
  scope             String?
  idToken          String?
  sessionState     String?

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Email {
  id            String    @id @default(cuid())
  userId        String
  folder        String    @default("inbox")
  subject       String?
  text          String?
  html          String?
  from          String
  fromName      String?
  to            String
  toName        String?
  replyTo       String?
  cc           String?
  bcc          String?
  read          Boolean   @default(false)
  starred       Boolean   @default(false)
  pinned       Boolean   @default(false)
  archived     Boolean   @default(false)
  spam         Boolean   @default(false)
  trash        Boolean   @default(false)
  downloaded   Boolean   @default(false)
  remoteId     String?
  threadId     String?
  inReplyTo    String?
  references   String?
  headers      String?
  attachments  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([folder])
  @@index([read])
  @@index([threadId])
  @@index([createdAt])
}

model Contact {
  id              String    @id @default(cuid())
  userId          String
  name            String
  email           String
  phone           String?
  company         String?
  jobTitle        String?
  address        String?
  notes           String?
  avatarUrl       String?
  starred        Boolean   @default(false)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([userId])
  @@index([starred])
}

model CalendarEvent {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description String?
  location    String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  recurring   String?
  color       String?
  reminders   String?
  attendees   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startDate])
}

model Todo {
  id          String    @id @default(cuid())
  userId      String
  title       String
  completed   Boolean   @default(false)
  dueDate     DateTime?
  priority    String    @default("medium")
  category    String    @default("Travail")
  notes       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  completedAt DateTime?
  deletedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([completed])
  @@index([dueDate])
}

model Feed {
  id           String    @id @default(cuid())
  userId       String
  name         String
  url          String
  iconUrl      String?
  category     String?
  lastFetchedAt DateTime?
  unreadCount  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles     FeedArticle[]

  @@unique([userId, url])
  @@index([userId])
}

model FeedArticle {
  id          String    @id @default(cuid())
  feedId      String
  userId      String
  title       String
  summary     String?
  content     String?
  url         String
  author      String?
  publishedAt DateTime
  read        Boolean   @default(false)
  starred    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  feed        Feed      @relation(fields: [feedId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedId])
  @@index([userId])
  @@index([read])
  @@index([publishedAt])
}

model Bookmark {
  id          String    @id @default(cuid())
  userId      String
  title      String
  url        String
  description String?
  thumbnail  String?
  tags       String?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  theme                 String   @default("dark")
  language              String   @default("fr")
  emailView             String   @default("default")
  emailSort             String   @default("date desc")
  contactsSort         String   @default("name asc")
  calendarView         String   @default("month")
  todoView             String   @default("list")
  sidebarCollapsed      Boolean  @default(false)
  desktopNotifications Boolean  @default(true)
  emailNotifications   Boolean  @default(true)
  calendarNotifications Boolean @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SyncState {
  id            String   @id @default(cuid())
  userId        String
  lastSyncedAt  DateTime @default(now())
  syncToken    String?
  deviceId     String
  deviceName  String
  platform    String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([deviceId])
}