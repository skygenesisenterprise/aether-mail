{
  "name": "@aether-mail/electron",
  "version": "1.0.0",
  "description": "Electron main process for Aether Mail desktop app",
  "private": true,
  "type": "module",
  "main": "dist/index.cjs",
  "scripts": {
    "build": "esbuild main/index.ts --bundle --platform=node --outfile=dist/index.cjs --format=cjs --external:electron",
    "start": "electron .",
    "dev": "pnpm run build && pnpm exec electron ."
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.skygenesisenterprise.aether-mail",
    "productName": "Aether Mail",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}