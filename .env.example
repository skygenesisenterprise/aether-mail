IMAP_USE_TLS=true
IMAP_SKIP_VERIFY=true

SMTP_HOST=mail.skygenesisenterprise.net
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_SKIP_VERIFY=true

JWT_SECRET=your-secret-key-here
