STALWART_HOST=localhost
STALWART_HTTP_PORT=8080
STALWART_JMAP_PORT=8081
STALWART_IMAP_PORT=993
STALWART_SMTP_PORT=587
STALWART_USE_TLS=true
STALWART_SKIP_VERIFY=true

MAIL_PROVIDER=imap
