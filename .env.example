# Default embedded mail servers: mail.skygenesisenterprise.net (primary) and mail.skygenesisenterprise.com (secondary)
# The engine resolves the host automatically based on the email domain.
STALWART_HOST=mail.skygenesisenterprise.net
STALWART_HTTP_PORT=8080
STALWART_JMAP_PORT=8081
STALWART_IMAP_PORT=993
STALWART_SMTP_PORT=587
STALWART_USE_TLS=true
STALWART_SKIP_VERIFY=true

MAIL_PROVIDER=imap
IMAP_HOST=mail.skygenesisenterprise.net
IMAP_PORT=993
IMAP_USE_TLS=true
IMAP_SKIP_VERIFY=true

SMTP_HOST=mail.skygenesisenterprise.net
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_SKIP_VERIFY=true

JWT_SECRET=your-secret-key-here
JWT_EXPIRY=24h

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

LOG_LEVEL=info
LOG_FILE=./src/logs/server.log

# OAuth Providers (google, microsoft, proton)
# Set MAIL_PROVIDER to one of: stalwart, imap, google, microsoft, proton
OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/callback

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/google/callback

MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/microsoft/callback
MICROSOFT_TENANT=common

PROTON_CLIENT_ID=your-proton-client-id
PROTON_CLIENT_SECRET=your-proton-client-secret
PROTON_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/proton/callback